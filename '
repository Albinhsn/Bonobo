module Object where 

import Parser
import ParserUtils
import Ast 
import Lexer 
import Token 
import Utils 
import Data.Map (Map)
import Control.Monad.Free 

data ObjectType = NULL_OBJ | INT_OBJ | BOOL_OBJ deriving (Eq, Show) 

data Variable 
  = FuncVar{varIdent :: !String, params :: ![Expression], body :: ![Statement]}
  | LetVar {varIdent :: !String, letValue :: Object} 

data Object 
  = NullObject {objectType :: !ObjectType}
  | IntObject {objectType :: !ObjectType, intValue :: !Int}
  | BoolObject {objectType :: !ObjectType, boolValue :: !Bool}
  deriving(Eq, Show)

evaluateFunc :: ([Statement], [Variable]) -> Object
evaluateFunc (s,v) = NullObject{objectType = NULL_OBJ} 

evaluateProgram :: ([Statement],[Object])-> ([Statement],[Object]) 
evaluateProgram (s,o) = (st,ob) 
  where 
    (st, ob) 
      | null s = (s, 0)
      | otherwise = (removeFirst s, o ++ [evaluateStatement(head s)])

evaluateStatement :: Statement -> Object
evaluateStatement s= o 
  where 
    o 
      -- | null s =NullObject{objectType = NULL_OBJ} 
      | statementType s == LETSTA = evaluateExpression(expression s) 
      -- | statementType (head s) /= IFSTA || statementType (head s) /= FUNCSTA || statementType (head s) /= 
      | statementType s == IFSTA = evaluateIf(s)
      | otherwise = error  "got"

evaluateIf :: Statement-> Object 
evaluateIf s = o 
  where 
    o 
      | boolValue (evaluateExpression(expression s)) == True = evaluateStatement(last (getCon([s])))
      | null (alt(statementUni s)) == False = evaluateStatement(last (getAlt([s])))
      | otherwise = NullObject{objectType = NULL_OBJ} 

evaluateExpression :: Expression -> Object  
evaluateExpression e = o 
  where 
    o
      | expressionType e == INTEXP = IntObject{objectType = INT_OBJ, intValue = parseIntFromToken(integerLiteral e)}
      | expressionType e == TFEXP = BoolObject{objectType = BOOL_OBJ, boolValue = parseBoolFromTokenType(bool e)}
      | expressionType e == PREFIXEXP = parsePrefixObject(e) 
      | expressionType e == OPERATOREXP = parseOperatorObject(e)
      | expressionType e == BOOLEXP = parseBoolObject(e)
      | expressionType e == GROUPEDEXP = evaluateExpression(groupedExpression e)
      | otherwise = error ("error evaluating expression" ++ expressionToString(e))

inspectObject :: Object -> String 
inspectObject o = 
  case objectType o of 
    NULL_OBJ -> "null"
    INT_OBJ -> show (intValue o)
    BOOL_OBJ -> show(boolValue o) 

parseIntFromToken :: Token -> Int 
parseIntFromToken t = read (literal t)

parseBoolFromTokenType :: TokenType -> Bool 
parseBoolFromTokenType t = 
  case t of 
    TRUE -> True 
    FALSE -> False 
    _ -> error "parseBoolFromTokenType"

parsePrefixObject :: Expression -> Object 
parsePrefixObject e = o 
  where 
    o 
      | typ (prefixOperator e) == BANG = BoolObject{objectType = BOOL_OBJ, boolValue = parseBangValue(evaluateExpression(prefixExpression e))} 
      | typ (prefixOperator e) == MINUS = IntObject{objectType = INT_OBJ, intValue = parseMinusValue(evaluateExpression(prefixExpression e))}
      | otherwise = error "parsePrefixObject"


parseBangValue :: Object -> Bool 
parseBangValue o = b 
  where 
    b 
      | objectType o == BOOL_OBJ && boolValue o == True = False
      | objectType o == BOOL_OBJ && boolValue o == False = True 
      | otherwise = error "can't have bang prefix without bool expression" 

parseMinusValue :: Object -> Int
parseMinusValue o = i
  where 
    i 
      | objectType o == INT_OBJ =  -1 * (intValue o)
      | otherwise = error "can't have minus before non int"

parseOperatorObject :: Expression -> Object 
parseOperatorObject e = o   
  where 
    o 
      | typ (operator e) == PLUS = IntObject{objectType = INT_OBJ, intValue = (intValue (evaluateExpression(leftOperator e)) + intValue (evaluateExpression(rightOperator e)))} 
      | typ (operator e) == MINUS = IntObject{objectType = INT_OBJ, intValue = (intValue (evaluateExpression(leftOperator e)) - intValue (evaluateExpression(rightOperator e)))} 
      | typ (operator e) == ASTERISK = IntObject{objectType = INT_OBJ, intValue = (intValue (evaluateExpression(leftOperator e)) * intValue (evaluateExpression(rightOperator e)))} 
      | typ (operator e) == SLASH = IntObject{objectType = INT_OBJ, intValue = (intValue (evaluateExpression(leftOperator e)) `div` intValue (evaluateExpression(rightOperator e)))} 
      | otherwise = error (expressionToString e)

parseBoolObject :: Expression -> Object 
parseBoolObject e = o 
  where 
    o 
      | typ (boolOperator e) == EQUALS = BoolObject{objectType = BOOL_OBJ, boolValue = (evaluateExpression(leftBool e) == evaluateExpression(rightBool e))}
      | typ (boolOperator e) == NOT_EQUALS=BoolObject{objectType = BOOL_OBJ, boolValue = (evaluateExpression(leftBool e) /= evaluateExpression(rightBool e))}
      | typ (boolOperator e) == GREATER_T= BoolObject{objectType = BOOL_OBJ, boolValue = evaluateGT(evaluateExpression(leftBool e), evaluateExpression(rightBool e))} 
      | typ (boolOperator e) == LESS_T= BoolObject{objectType = BOOL_OBJ, boolValue = not (evaluateGT(evaluateExpression(leftBool e), evaluateExpression(rightBool e)))} 
      | otherwise = error "parseBoolObject"

evaluateGT :: (Object, Object) -> Bool 
evaluateGT (o1, o2) = b 
  where   
    b 
      | objectType o1 == INT_OBJ && objectType o2 == INT_OBJ && intValue o1 > intValue o2 = True 
      | objectType o1 == INT_OBJ && objectType o2 == INT_OBJ = False 
      | otherwise = error "can't evaluate since both are not ints"

evaluateLT :: (Object, Object) -> Bool 
evaluateLT (o1, o2) = True
